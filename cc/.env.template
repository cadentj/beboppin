# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=cc
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional Google Calendar / Tasks OAuth.
# Create OAuth credentials, grant Calendar readonly and Tasks readonly scopes,
# then store the refresh token and client credentials as Wrangler secrets.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_TASK_LIST_ID=@default

# Viewer auth. Requests to the web UI need either:
# Authorization: Bearer <WEB_AUTH_TOKEN> or ?token=<WEB_AUTH_TOKEN>
WEB_AUTH_TOKEN=

# Bot behavior
TIMEZONE=America/New_York
LONG_TEXT_MIN_CHARS=240
