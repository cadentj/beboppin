{
  "name": "cc",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev:worker": "wrangler dev",
    "dev:web": "vite --config web/vite.config.ts",
    "dev": "concurrently -n worker,web -c blue,magenta \"pnpm dev:worker\" \"pnpm dev:web\"",
    "build:web": "vite build --config web/vite.config.ts",
    "deploy": "pnpm build:web && wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply cc --remote",
    "typecheck": "tsc --noEmit && svelte-check --workspace web"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260424.1",
    "@sveltejs/vite-plugin-svelte": "6.2.1",
    "@tailwindcss/vite": "4.2.4",
    "concurrently": "9.2.1",
    "daisyui": "5.2.4",
    "svelte": "5.50.2",
    "svelte-check": "4.4.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "vite": "7.2.4",
    "wrangler": "4.84.1"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "ai": "^6.0.168"
  }
}
